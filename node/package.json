{
  "name": "@deepstrike/sdk",
  "version": "0.2.39",
  "description": "DeepStrike Node.js SDK",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./providers": {
      "types": "./dist/providers/public.d.ts",
      "import": "./dist/providers/public.js"
    },
    "./workflow": {
      "types": "./dist/workflow/public.d.ts",
      "import": "./dist/workflow/public.js"
    },
    "./planes": {
      "types": "./dist/planes/public.d.ts",
      "import": "./dist/planes/public.js"
    },
    "./memory": {
      "types": "./dist/memory/public.d.ts",
      "import": "./dist/memory/public.js"
    },
    "./harness": {
      "types": "./dist/harness/public.d.ts",
      "import": "./dist/harness/public.js"
    },
    "./os": {
      "types": "./dist/os/public.d.ts",
      "import": "./dist/os/public.js"
    }
  },
  "typesVersions": {
    "*": {
      "providers": [
        "./dist/providers/public.d.ts"
      ],
      "workflow": [
        "./dist/workflow/public.d.ts"
      ],
      "planes": [
        "./dist/planes/public.d.ts"
      ],
      "memory": [
        "./dist/memory/public.d.ts"
      ],
      "harness": [
        "./dist/harness/public.d.ts"
      ],
      "os": [
        "./dist/os/public.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:e2e": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern e2e/run --testTimeout 300000",
    "test:e2e:k": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern e2e/run --testTimeout 300000",
    "test:local-core": "cd ../crates/deepstrike-node && napi build --platform && cd ../../node && npm test",
    "smoke:providers": "node ../scripts/smoke-node-provider-loops.mjs",
    "e2e": "node ../scripts/run-e2e.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "@deepstrike/core": "0.2.39",
    "@google/generative-ai": "^0.24.1",
    "openai": "^5.23.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  }
}
