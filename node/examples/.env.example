# Copy to node/examples/.env and fill the provider settings you want to test.

# Provider selection. Supported by this demo: openai, anthropic, minimax,
# deepseek, kimi, qwen, gemini, glm, ollama.
DEEPSTRIKE_PROVIDER=openai
DEEPSTRIKE_MODEL=openai/gpt-4o-mini

# Prefer provider-specific keys for normal usage. DEEPSTRIKE_API_KEY is accepted
# as a provider-agnostic override.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
DASHSCOPE_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
GLM_API_KEY=
DEEPSTRIKE_API_KEY=

# Optional endpoint overrides for custom OpenAI-compatible gateways.
# DEEPSTRIKE_ENDPOINT=openai.chat
# DEEPSTRIKE_BASE_URL=https://api.openai.com/v1

# Stability load shape.
DEEPSTRIKE_TARGET_STEPS=30
DEEPSTRIKE_CHECKPOINT_EVERY=5
DEEPSTRIKE_LARGE_RESULT_EVERY=10
DEEPSTRIKE_LARGE_RESULT_KIB=80
DEEPSTRIKE_MAX_TURNS=90
DEEPSTRIKE_TIMEOUT_MS=1800000
DEEPSTRIKE_MAX_TOKENS=160000

# Reuse a session id to test replay/wake.
# DEEPSTRIKE_SESSION_ID=node-stability-manual
# DEEPSTRIKE_WAKE=1

# M2 resource quota path.
DEEPSTRIKE_MAX_CONCURRENT_SUBAGENTS=2
DEEPSTRIKE_MAX_SPAWN_DEPTH=2
DEEPSTRIKE_MEMORY_WRITES_PER_WINDOW=200
DEEPSTRIKE_MEMORY_WRITE_WINDOW_MS=60000

# Spool path behavior.
DEEPSTRIKE_SPOOL_THRESHOLD_BYTES=51200
DEEPSTRIKE_SPOOL_PREVIEW_TOKENS=500

# Print live kernel primitive dashboard.
DEEPSTRIKE_DIAGNOSTICS=0
